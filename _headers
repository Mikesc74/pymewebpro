# Cloudflare Pages _headers
# Format: blank line between blocks. First line of each block is a path
# pattern; following indented lines are headers to add to responses for
# matching paths.
#
# Pattern /* matches every path. To override per-path, add another block
# with a more specific pattern below (Pages picks the most specific match).
#
# CSP NOTE: script-src has SHA-256 hashes for each inline JSON-LD block in
# index.html. If you edit ANY JSON-LD content (including whitespace), the
# hash changes and the browser will refuse to render the block. Recompute:
#
#   python3 -c "import re,hashlib,base64; html=open('index.html').read();
#   [print(\"'sha256-\"+base64.b64encode(hashlib.sha256(m.group(1).encode()).digest()).decode()+\"'\")
#    for m in re.finditer(r'<script type=\"application/ld\+json\">(.*?)</script>', html, re.DOTALL)]"

/*
  Strict-Transport-Security: max-age=31536000
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.googletagmanager.com 'sha256-63/gh2DpB3/anUv/VT4m7aOT7exeE0VvJceSbwgM+Ks=' 'sha256-2wNOcn9npIZupmRFgAPRJH0QVWqewpwaY9B9s5NdaoE=' 'sha256-eG+U0UoTj4hZW0SCk7Plel9p4otrO5f17fcLDO0077w=' 'sha256-/4FfLBeLDFM8ToHgOvn793TuhUsxy1toI8/i7hZ67Yg=' 'sha256-jKSZec9alXPl5oTTyxfpHxo4/kk2wNUFwvEUnJ6A+dk=' 'sha256-Z1XkC0dSjaeXfPJAWyCV0/Z881QY2FY87qxV/JswQjs='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com https://*.analytics.google.com; form-action 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Cache HTML docs at the edge for 24h with stale-while-revalidate. Browsers
# revalidate after 10 min; the CDN serves cached HTML for a day and refreshes
# in the background. Without this Cloudflare Pages defaults to max-age=0
# must-revalidate which defeats edge caching entirely.

/
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/terminos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/politica-de-datos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/hosting.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

# External stylesheet — long browser cache, ETag-based revalidation handles updates.
# If you make a CSS change visitors must see immediately, append ?v=2 (etc.) to
# the <link href="/styles.css?v=N"> in both index.html and en/index.html.

/styles.css
  Cache-Control: public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800
