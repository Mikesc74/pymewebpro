# Cloudflare Pages _headers
# Format: blank line between blocks. First line of each block is a path
# pattern; following indented lines are headers to add to responses for
# matching paths.
#
# Pattern /* matches every path. To override per-path, add another block
# with a more specific pattern below (Pages picks the most specific match).
#
# CSP NOTE: Content-Security-Policy is NOT set here. It is set by the Pages
# Function at functions/_middleware.js because the hash-locked CSP value
# exceeds Cloudflare Pages' ~2000-char per-header-value limit on _headers
# entries. Oversized values are silently stripped, so a CSP defined here
# never reaches the wire. See functions/_middleware.js for the full CSP
# definition and hash-recompute instructions.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Cache HTML docs at the edge for 24h with stale-while-revalidate. Browsers
# revalidate after 10 min; the CDN serves cached HTML for a day and refreshes
# in the background. Without this Cloudflare Pages defaults to max-age=0
# must-revalidate which defeats edge caching entirely.

/
  Cache-Control: public, max-age=600, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/es/
  Cache-Control: public, max-age=600, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=86400

# Pretty-URL paths. Cloudflare Pages serves /name.html at /name and 308-redirects
# /name.html → /name, so the canonical URL is the extension-less form.

/terminos
  Cache-Control: public, max-age=600, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/politica-de-datos
  Cache-Control: public, max-age=600, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/privacy
  Cache-Control: public, max-age=600, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/hosting
  Cache-Control: public, max-age=600, must-revalidate
  CDN-Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

# External stylesheet — long browser cache, ETag-based revalidation handles updates.
# If you make a CSS change visitors must see immediately, append ?v=2 (etc.) to
# the <link href="/styles.css?v=N"> in both index.html and en/index.html.

/styles.css
  Cache-Control: public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800

# Portfolio + assets — long browser cache, content-addressable filenames change.
/screenshots/*
  Cache-Control: public, max-age=2592000, s-maxage=2592000, immutable
/og-image.png
  Cache-Control: public, max-age=2592000, s-maxage=2592000
