# Cloudflare Pages _headers
# Format: blank line between blocks. First line of each block is a path
# pattern; following indented lines are headers to add to responses for
# matching paths.
#
# Pattern /* matches every path. To override per-path, add another block
# with a more specific pattern below (Pages picks the most specific match).
#
# CSP NOTE: script-src has SHA-256 hashes for each inline JSON-LD block in
# index.html. If you edit ANY JSON-LD content (including whitespace), the
# hash changes and the browser will refuse to render the block. Recompute:
#
#   python3 -c "import re,hashlib,base64; html=open('index.html').read();
#   [print(\"'sha256-\"+base64.b64encode(hashlib.sha256(m.group(1).encode()).digest()).decode()+\"'\")
#    for m in re.finditer(r'<script type=\"application/ld\+json\">(.*?)</script>', html, re.DOTALL)]"

/*
  Strict-Transport-Security: max-age=31536000
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-pe7aeDxeDlosz8NNy/+WZWADwnUMIqe3bLxHXCAYFwM=' 'sha256-TF+7VwuZqPg2ESNF4RPtZtd4IAY+1M6rHZeXogtop8M=' 'sha256-3qJeKqM0UNi1HZHbMMFDJxewxL3rvdeo20Ek9qLv9kY=' 'sha256-/4FfLBeLDFM8ToHgOvn793TuhUsxy1toI8/i7hZ67Yg=' 'sha256-jKSZec9alXPl5oTTyxfpHxo4/kk2wNUFwvEUnJ6A+dk=' 'sha256-x9W/JJ2P8D7b3FHQPHtjK0LbyRawOha1B97m/8HUQ/8='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Cache HTML docs at the edge for 24h with stale-while-revalidate. Browsers
# revalidate after 10 min; the CDN serves cached HTML for a day and refreshes
# in the background. Without this Cloudflare Pages defaults to max-age=0
# must-revalidate which defeats edge caching entirely.

/
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/terminos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/politica-de-datos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/hosting.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600
