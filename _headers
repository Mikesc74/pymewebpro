# pattern; following indented lines are headers to add to responses for
# matching paths.
#
# Pattern /* matches every path. To override per-path, add another block
# with a more specific pattern below (Pages picks the most specific match).
#
# CSP NOTE: script-src has SHA-256 hashes for each inline <script> block in
# index.html. If you edit ANY inline-script content (including whitespace),
# the hash changes and the browser will refuse to execute the block. Recompute
# all inline-script hashes with:
#
#   python3 -c "import re,hashlib,base64; html=open('index.html').read();
#   [print(\"'sha256-\"+base64.b64encode(hashlib.sha256(m.group(2).encode()).digest()).decode()+\"'\")
#    for m in re.finditer(r'<script(\s[^>]*)?>(.*?)</script>', html, re.DOTALL)
#    if 'src=' not in (m.group(1) or '') and m.group(2).strip()]"

