# Cache HTML docs at the edge for 24h with stale-while-revalidate. Browsers
# revalidate after 10 min; the CDN serves cached HTML for a day and refreshes
# in the background. Without this Cloudflare Pages defaults to max-age=0
# must-revalidate which defeats edge caching entirely.

/
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/es/
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/terminos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/politica-de-datos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/hosting.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

# External stylesheet — long browser cache, ETag-based revalidation handles updates.
# If you make a CSS change visitors must see immediately, append ?v=2 (etc.) to
# the <link href="/styles.css?v=N"> in both index.html and en/index.html.

/styles.css
  Cache-Control: public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800
