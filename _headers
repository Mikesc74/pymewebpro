# Cloudflare Pages _headers
# Format: blank line between blocks. First line of each block is a path
# pattern; following indented lines are headers to add to responses for
# matching paths.
#
# Pattern /* matches every path. To override per-path, add another block
# with a more specific pattern below (Pages picks the most specific match).
#
# CSP NOTE: script-src has SHA-256 hashes for each inline <script> block in
# index.html. If you edit ANY inline-script content (including whitespace),
# the hash changes and the browser will refuse to execute the block. Recompute
# all inline-script hashes with:
#
#   python3 -c "import re,hashlib,base64; html=open('index.html').read();
#   [print(\"'sha256-\"+base64.b64encode(hashlib.sha256(m.group(2).encode()).digest()).decode()+\"'\")
#    for m in re.finditer(r'<script(\s[^>]*)?>(.*?)</script>', html, re.DOTALL)
#    if 'src=' not in (m.group(1) or '') and m.group(2).strip()]"

/*
  Strict-Transport-Security: max-age=31536000
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-sCqmJXNHEBoEhn+RcmjrbHjJ3QGXn3kpvgouD4TXcaU='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Cache HTML docs at the edge for 24h with stale-while-revalidate. Browsers
# revalidate after 10 min; the CDN serves cached HTML for a day and refreshes
# in the background. Without this Cloudflare Pages defaults to max-age=0
# must-revalidate which defeats edge caching entirely.

/
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/terminos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/politica-de-datos.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/hosting.html
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

# External stylesheet — long browser cache, ETag-based revalidation handles updates.
# If you make a CSS change visitors must see immediately, append ?v=2 (etc.) to
# the <link href="/styles.css?v=N"> in both index.html and en/index.html.

/styles.css
  Cache-Control: public, max-age=86400, s-maxage=604800, stale-while-revalidate=604800
